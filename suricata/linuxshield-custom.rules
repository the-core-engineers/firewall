# linuxshield-custom.rules
# ─────────────────────────
# Custom Suricata IPS rules for LinuxShield.
# Reference: https://suricata.readthedocs.io/en/latest/rules/intro.html
#
# Rule anatomy:
#   action proto src_ip src_port direction dst_ip dst_port (options)
#
# action: alert (log only) | drop (IPS mode) | pass (whitelist)
# direction: -> (one way) | <> (bidirectional)

# ── Port scanning detection ───────────────────────────────────────────────────
# Suricata detects Nmap SYN scans by spotting many SYN packets with no ACK
# to multiple ports from one source within a short window.
alert tcp $EXTERNAL_NET any -> $HOME_NET any \
    (msg:"LinuxShield Port Scan Detected"; \
     flags:S; threshold:type both,track by_src,count 20,seconds 5; \
     classtype:network-scan; sid:9000001; rev:1;)

# ── SSH brute-force ───────────────────────────────────────────────────────────
drop tcp $EXTERNAL_NET any -> $HOME_NET 22 \
    (msg:"LinuxShield SSH Brute Force"; \
     flow:to_server,established; content:"SSH"; \
     threshold:type threshold,track by_src,count 5,seconds 60; \
     classtype:attempted-admin; sid:9000002; rev:1;)

# ── HTTP directory traversal ──────────────────────────────────────────────────
drop http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS \
    (msg:"LinuxShield Directory Traversal"; \
     flow:to_server,established; \
     content:"../"; http_uri; \
     classtype:web-application-attack; sid:9000003; rev:1;)

# ── SQL injection attempt ─────────────────────────────────────────────────────
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS \
    (msg:"LinuxShield SQL Injection Attempt"; \
     flow:to_server,established; \
     content:"UNION SELECT"; http_uri; nocase; \
     classtype:web-application-attack; sid:9000004; rev:1;)

# ── DNS amplification (large DNS responses to spoofed source) ─────────────────
alert udp $HOME_NET 53 -> $EXTERNAL_NET any \
    (msg:"LinuxShield DNS Amplification Response"; \
     dsize:>512; threshold:type both,track by_src,count 100,seconds 10; \
     classtype:attempted-dos; sid:9000005; rev:1;)

# ── ICMP flood ────────────────────────────────────────────────────────────────
drop icmp $EXTERNAL_NET any -> $HOME_NET any \
    (msg:"LinuxShield ICMP Flood"; \
     itype:8; threshold:type both,track by_src,count 100,seconds 5; \
     classtype:attempted-dos; sid:9000006; rev:1;)
